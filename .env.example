APP_NAME="Mochi Cards"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Auf dem Test-/Live-Server (Beispiel):
# APP_ENV=production
# APP_DEBUG=false
# LOG_LEVEL=warning
# Auf dem Test-/Live-Server immer HTTPS verwenden (verhindert Mixed-Content mit Vite-Assets).
APP_URL=http://127.0.0.1:8008
# Optional: feste Asset-Basis (CDN oder gleicher Host mit HTTPS). Leer = wie APP_URL.
# ASSET_URL=

# --- Production (VM /var/www/mochi-cards) — Pflicht gegen Chrome „Nicht sicher“ / Mixed Content ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://mochi-cards.de
# ASSET_URL=https://mochi-cards.de
# SESSION_SECURE_COOKIE=true
# FORCE_HTTPS=true
# (APP_URL mit https:// aktiviert force_https auch ohne FORCE_HTTPS=true)

# Mochi Cards (optional overrides)
# MOCHI_SITE_NAME="Mochi Cards"
# MOCHI_INSTAGRAM_URL="https://www.instagram.com/"
# MOCHI_SHOP_URL="https://your-shop.example"
# MOCHI_TIKTOK_URL=
# Google-Maps-Fallback „Besuch uns im Laden“, wenn im Admin leer
# MOCHI_VISIT_STORE_URL="https://www.google.com/maps/search/?api=1&query=Mochi+Cards+Speyer+Germany"
# Event-Kalender-Feed: Server-Cache (Sekunden) und Browser max-age
# MOCHI_EVENTS_FEED_CACHE_SECONDS=600
# MOCHI_EVENTS_FEED_HTTP_MAX_AGE=300
# Startseite: Hero-Headline & Shop-Highlight-Fallback (wenn Admin leer)
# MOCHI_HERO_HEADLINE="Dein TCG WOHNZIMMER IN Speyer"
# MOCHI_FEATURED_TITLE="Shop-Highlight: Kevko's Community Token - Limitierte Edition"
# MOCHI_FEATURED_DESCRIPTION="Einzeiliger Kurztext; für längere Texte Admin nutzen."
# News-Bereich: Vorschau wenn keine Beiträge online
# MOCHI_NEWS_FALLBACK_TITLE="Wir haben aufgerüstet: Mehr Platz für eure Matches!"
# MOCHI_NEWS_FALLBACK_BODY="Einladender Kurztext zum Laden und zur Community."

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

MOCHI_SITE_NAME="Mochi Cards"
MOCHI_INSTAGRAM_URL=https://www.instagram.com/

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# Marken-503 beim Wartungsmodus: php artisan down --render=errors.503

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
# Standard-Web-Session (Minuten Inaktivität). Filament-Admin: FILAMENT_SESSION_LIFETIME (siehe unten).
SESSION_LIFETIME=120
# Production hinter HTTPS: SESSION_SECURE_COOKIE=true, SESSION_HTTP_ONLY=true. Lokal ohne TLS: SECURE false.
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_ENCRYPT=false
# Alle Web-Requests auf HTTPS umleiten. In Production empfohlen; alternativ reicht APP_URL=https://…
# FORCE_HTTPS=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Filament-Admin: kürzere Session bei Inaktivität (Minuten), unabhängig von SESSION_LIFETIME.
FILAMENT_SESSION_LIFETIME=120
# Preview/Lokal: Passkey-MFA für Admin optional. Production sollte true sein.
FILAMENT_REQUIRE_2FA=false
# WebAuthn/Passkeys (MFA nach E-Mail+Passwort). Relying Party = Domain aus APP_URL, z. B. mochi-cards.de
# PASSKEYS_RELYING_PARTY_ID=mochi-cards.de
# PASSKEYS_ALLOWED_ORIGINS=https://mochi-cards.de
# PASSKEYS_USER_HANDLE_SECRET=
# PASSKEYS_TIMEOUT=60000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: log (dev) | smtp | resend (empfohlen für Produktion)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (https://resend.com) — Domain verifizieren, dann:
# MAIL_MAILER=resend
# MAIL_FROM_ADDRESS="noreply@deine-domain.de"
# RESEND_API_KEY=re_xxxxxxxx
# Alternativ SMTP von Resend: MAIL_MAILER=smtp, Host smtp.resend.com, Port 465,
# Username=resend, Password=<API-Key>
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Nächtliches DB-Backup (Spatie): Ziel-Disks aus config/filesystems.php, kommagetrennt.
# SQLite-Backup setzt die CLI „sqlite3“ voraus (auf Linux/MySQL i. d. R. unproblematisch).
# Beispiel nur S3: BACKUP_DESTINATION_DISKS=s3
# BACKUP_DESTINATION_DISKS=local,s3
# Starke Passphrase für verschlüsselte Backup-ZIP empfohlen.
# BACKUP_ARCHIVE_PASSWORD=

# Fehler-Monitoring (Checkout-500er u. a.): DSN aus Sentry-Projekt.
# SENTRY_LARAVEL_DSN=
# SENTRY_ENVIRONMENT=production

VITE_APP_NAME="${APP_NAME}"

# Cloudflare Turnstile (optional, Kontaktformular). Ohne Secret wird nicht geprüft.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# SumUp (Online-Shop — gleiches Händlerkonto wie Ladenterminal)
# SUMUP_TOKEN=
# SUMUP_MERCHANT_CODE=
# Optional: Pfad zum SumUp-Produkt-CSV-Export (für shop:sumup-sync-catalog)
# SUMUP_CATALOG_CSV_PATH=/var/www/mochi-cards/storage/app/sumup-catalog.csv
# Kontakt: Google-Maps-Embed-URL (iframe src), Dark-Look per CSS-Filter im Layout
# MOCHI_MAPS_EMBED_URL="https://maps.google.com/maps?q=...&output=embed"
# MOCHI_CONTACT_INTRO="Kurzer Einleitungstext auf /kontakt"
